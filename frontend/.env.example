# API base URL. Leave empty in dev to use Vite proxy (backend on :3001).
# In production: set to your backend URL before running npm run build.
# VITE_* vars are baked in at build time, not at runtime.
# Example (Railway): https://brainfeed-backend-production.up.railway.app
VITE_API_URL=https://brainfeed-backend-production.up.railway.app
