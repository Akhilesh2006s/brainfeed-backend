PORT=3001
NODE_ENV=production
HOST=0.0.0.0
# Optional: frontend URL(s) for CORS (comma-separated). Built-in: Vercel + localhost:5173, localhost:8080.
# On Railway set e.g.: CORS_ORIGIN=https://brainfeed-frontend.vercel.app,http://localhost:8080
# CORS_ORIGIN=

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

MONGO_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/your_database?appName=Cluster0

JWT_SECRET=your_jwt_secret

ADMIN_EMAIL=admin@brainfeed.com
ADMIN_PASSWORD=12345678
